  m_text: "\u0420\u0430\u0437\u0432\u0438\u0442\u0438\u0435 \u043C\u0430\u0441\u0442\u0435\u0440\u0430:\r\n\u0422\u0440\u0435\u043D\u0438\u0440\u043E\u0432\u043A\u0430
    \u0442\u0435\u043B\u0430 - \u0443\u0432\u0435\u043B\u0438\u0447\u0435\u043D\u0438\u0435
    \u043F\u0430\u0440\u0430\u043C\u0435\u0442\u0440\u0430 \u0442\u0435\u043B\u0430,
    \u0432\u043B\u0438\u044F\u044E\u0449\u0435\u0433\u043E \u043D\u0430 HP \u0438
    \u0443\u0440\u043E\u043D.\r\n\u041C\u0435\u0434\u0438\u0442\u0430\u0446\u0438\u044F
    - \u043D\u0430\u043A\u043E\u043F\u043B\u0435\u043D\u0438\u0435 \u0446\u0438,
    \u0433\u0434\u0435 \u043D\u0443\u0436\u043D\u043E \u0443\u0434\u0435\u0440\u0436\u0438\u0432\u0430\u0442\u044C
    \u0448\u0430\u0440 \u0432 \u043D\u0443\u0436\u043D\u043E\u0439 \u0441\u043A\u043E\u0440\u043E\u0441\u0442\u0438.\r\n\u041F\u0440\u043E\u0440\u044B\u0432
    \u043C\u0435\u0440\u0438\u0434\u0438\u0430\u043D\u043E\u0432 - \u0442\u0440\u0430\u0442\u0430
    \u0446\u0438 \u043D\u0430 \u043E\u0442\u043A\u0440\u044B\u0442\u0438\u0435 \u043C\u0435\u0440\u0438\u0434\u0438\u0430\u043D\u043E\u0432
    \u0434\u043B\u044F \u0443\u0441\u0438\u043B\u0435\u043D\u0438\u044F \u043C\u0430\u0441\u0442\u0435\u0440\u0430,
    \u0433\u0434\u0435 \u043D\u0443\u0436\u043D\u043E \u043F\u043E\u043F\u0430\u0441\u0442\u044C
    \u0448\u0430\u0440\u043E\u043C \u0432 \u0437\u0430\u043A\u0440\u044B\u0442\u044B\u0435
    \u0443\u0437\u043B\u044B.\r\n\u041F\u0440\u043E\u0440\u044B\u0432 \u0440\u0430\u043D\u0433\u0430
    - \u0438\u0441\u043F\u044B\u0442\u0430\u043D\u0438\u0435 \u0434\u043B\u044F \u043F\u043E\u0432\u044B\u0448\u0435\u043D\u0438\u044F
    \u0443\u0440\u043E\u0432\u043D\u044F, \u0434\u043E\u0441\u0442\u0443\u043F\u043D\u043E\u0435
    \u043F\u0440\u0438 \u0434\u043E\u0441\u0442\u0430\u0442\u043E\u0447\u043D\u043E\u043C
    \u0443\u0440\u043E\u0432\u043D\u0435 \u0442\u0435\u043B\u0430, \u043C\u0435\u0440\u0438\u0434\u0438\u0430\u043D\u043E\u0432
    \u0438 \u0446\u0438.\r\n"
